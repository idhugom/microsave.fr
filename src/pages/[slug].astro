---
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { articles, categoryOf, fmtDate, related } from '../lib/articles';

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props;
const cat = categoryOf(article);
const rel = related(article, 3);

// ---- Build table of contents + inject heading ids ----
const slugify = (s: string) =>
  s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '')
    .replace(/<[^>]+>/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '').slice(0, 60);

const toc: { id: string; text: string }[] = [];
let n = 0;
const body = article.body_html.replace(/<h2([^>]*)>([\s\S]*?)<\/h2>/gi, (_m, attrs, inner) => {
  const text = inner.replace(/<[^>]+>/g, '').trim();
  const id = `${slugify(text) || 'section'}-${++n}`;
  toc.push({ id, text });
  return `<h2 id="${id}"${attrs}>${inner}</h2>`;
});

const site = 'https://www.microsave.fr';
const url = `${site}/${article.slug}/`;
const jsonld: Record<string, any>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: article.title,
    description: article.meta_description,
    image: article.image ? new URL(article.image, site).href : `${site}/og-default.png`,
    datePublished: article.date,
    dateModified: article.date,
    author: { '@type': 'Organization', name: 'Microsave' },
    publisher: { '@type': 'Organization', name: 'Microsave', logo: { '@type': 'ImageObject', url: `${site}/logo-microsave.svg` } },
    mainEntityOfPage: url,
    articleSection: cat.label,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: cat.label, item: `${site}/categorie/${cat.slug}/` },
      { '@type': 'ListItem', position: 3, name: article.title, item: url },
    ],
  },
];
if (article.faq?.length) {
  jsonld.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: article.faq.map((f) => ({
      '@type': 'Question', name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  });
}
---
<Base
  title={article.meta_title}
  description={article.meta_description}
  image={article.image}
  type="article"
  canonical={url}
  jsonld={jsonld}
  bodyClass="article-page"
>
  <div id="progress" class="progress" aria-hidden="true"></div>

  <article>
    <header class="a-hero" style={`--cc:${cat.color}`}>
      <div class="wrap">
        <nav class="crumbs" aria-label="Fil d’Ariane">
          <a href="/">Accueil</a><span>/</span>
          <a href={`/categorie/${cat.slug}/`}>{cat.label}</a>
        </nav>
        <span class="chip" style={`--cc:${cat.color}`}>{cat.label}</span>
        <h1>{article.title}</h1>
        <p class="dek">{article.excerpt}</p>
        <div class="a-meta">
          <span>Publié le {fmtDate(article.date)}</span>
          <span class="sep">•</span>
          <span>{article.reading_time_min} min de lecture</span>
        </div>
      </div>
    </header>

    {article.image && (
      <figure class="a-figure wrap">
        <img src={article.image} alt={article.image_alt} width="1536" height="1024" fetchpriority="high" decoding="async" transition:name={`img-${article.slug}`} />
      </figure>
    )}

    <div class="a-shell wrap">
      {toc.length > 2 && (
        <aside class="toc" aria-label="Sommaire">
          <p class="toc-title">Au sommaire</p>
          <ol>
            {toc.map((t) => (<li><a href={`#${t.id}`}>{t.text}</a></li>))}
          </ol>
        </aside>
      )}

      <div class="a-main">
        {article.key_takeaways?.length > 0 && (
          <div class="takeaways" style={`--cc:${cat.color}`}>
            <p class="tk-title">À retenir</p>
            <ul>
              {article.key_takeaways.map((k) => (<li>{k}</li>))}
            </ul>
          </div>
        )}

        <div class="prose" set:html={body} />

        {article.faq?.length > 0 && (
          <section class="faq" aria-label="Questions fréquentes">
            <h2>Questions fréquentes</h2>
            {article.faq.map((f, i) => (
              <details open={i === 0}>
                <summary>{f.question}</summary>
                <div class="ans"><p>{f.answer}</p></div>
              </details>
            ))}
          </section>
        )}

        {article.tags?.length > 0 && (
          <div class="a-tags">
            {article.tags.map((t) => (<span class="pill">#{t}</span>))}
          </div>
        )}

        <div class="a-foot">
          <a href={`/categorie/${cat.slug}/`} class="btn btn-ghost">← Plus de {cat.label}</a>
        </div>
      </div>
    </div>

    {rel.length > 0 && (
      <section class="wrap related">
        <div class="section-head"><div><span class="kicker">À lire ensuite</span><h2>Dans le même esprit</h2></div></div>
        <div class="rel-grid">
          {rel.map((a, i) => (<ArticleCard article={a} delay={i + 1} />))}
        </div>
      </section>
    )}
  </article>
</Base>

<style>
  .progress { position: fixed; top: 0; left: 0; height: 3px; width: 100%; background: linear-gradient(90deg, var(--pink), var(--ink)); transform: scaleX(0); transform-origin: 0 50%; z-index: 150; }

  .a-hero { padding-top: clamp(1.4rem, 4vw, 2.6rem); padding-bottom: clamp(1.2rem, 3vw, 1.8rem); }
  .crumbs { display: flex; gap: .5em; align-items: center; font-size: .85rem; color: var(--slate); margin-bottom: 1rem; }
  .crumbs a:hover { color: var(--pink-deep); }
  .a-hero .chip { margin-bottom: 1rem; }
  .a-hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.06; max-width: 20ch; letter-spacing: -.025em; }
  .a-hero .dek { font-size: clamp(1.08rem, 2vw, 1.35rem); color: var(--text-soft); max-width: 60ch; margin: 1rem 0 1.2rem; line-height: 1.55; }
  .a-meta { display: flex; gap: .6em; align-items: center; font-size: .9rem; color: var(--slate); }
  .a-meta .sep { color: var(--cc); }

  .a-figure { margin: 0 auto clamp(1.5rem, 4vw, 2.6rem); }
  .a-figure img { width: 100%; aspect-ratio: 3/2; object-fit: cover; border-radius: clamp(16px, 3vw, 28px); box-shadow: var(--shadow-lg); }

  .a-shell { display: grid; grid-template-columns: 230px minmax(0, 760px); gap: clamp(1.5rem, 4vw, 3.4rem); justify-content: center; align-items: start; }
  .toc { position: sticky; top: 100px; font-size: .9rem; }
  .toc-title { font-weight: 700; font-size: .72rem; letter-spacing: .1em; text-transform: uppercase; color: var(--slate); margin-bottom: .8rem; }
  .toc ol { list-style: none; padding: 0; display: grid; gap: .1rem; border-left: 2px solid var(--line); }
  .toc a { display: block; padding: .38em .9em; color: var(--text-soft); border-left: 2px solid transparent; margin-left: -2px; transition: color .25s, border-color .25s; line-height: 1.3; }
  .toc a:hover { color: var(--ink); border-left-color: var(--pink); }
  @media (max-width: 1000px) { .a-shell { grid-template-columns: minmax(0, 760px); } .toc { display: none; } }

  .takeaways { background: linear-gradient(135deg, color-mix(in srgb, var(--cc) 10%, #fff), #fff); border: 1px solid color-mix(in srgb, var(--cc) 26%, transparent); border-radius: 20px; padding: 1.5rem 1.6rem; margin-bottom: 2.2rem; position: relative; }
  .takeaways::before { content: "✦"; position: absolute; top: 1.4rem; right: 1.5rem; color: var(--cc); font-size: 1.2rem; }
  .tk-title { font-family: var(--font-body); font-weight: 750; font-size: .74rem; letter-spacing: .1em; text-transform: uppercase; color: var(--cc); margin-bottom: .8rem; }
  .takeaways ul { margin: 0; padding-left: 1.2em; display: grid; gap: .55rem; }
  .takeaways li { color: var(--ink-2); line-height: 1.5; }
  .takeaways li::marker { color: var(--cc); }

  .faq { margin-top: 3rem; }
  .faq > h2 { font-size: clamp(1.5rem, 3vw, 2rem); margin-bottom: 1.2rem; }
  .faq details { border: 1px solid var(--line); border-radius: 14px; margin-bottom: .7rem; background: #fff; overflow: hidden; transition: box-shadow .3s; }
  .faq details[open] { box-shadow: var(--shadow); }
  .faq summary { cursor: pointer; padding: 1.05em 1.2em; font-family: var(--font-display); font-size: 1.12rem; color: var(--ink); font-weight: 560; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: "+"; font-size: 1.5rem; color: var(--pink); transition: transform .3s; line-height: 1; }
  .faq details[open] summary::after { transform: rotate(45deg); }
  .faq .ans { padding: 0 1.2em 1.15em; color: var(--text-soft); line-height: 1.6; }

  .a-tags { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: 2.4rem; }
  .pill { font-size: .82rem; color: var(--text-soft); background: var(--paper-2); border: 1px solid var(--line); padding: .32em .8em; border-radius: 100px; }
  .a-foot { margin-top: 2.4rem; padding-top: 1.6rem; border-top: 1px solid var(--line); }

  .related { margin-top: clamp(3rem, 7vw, 5rem); }
  .rel-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 800px) { .rel-grid { grid-template-columns: 1fr; } }
</style>
