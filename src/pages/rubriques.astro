---
import Base from '../layouts/Base.astro';
import { inCategory, articles } from '../lib/articles';
import { CATEGORIES } from '../lib/categories';

const data = CATEGORIES
  .map((c) => ({ c, items: inCategory(c.label) }))
  .filter((x) => x.items.length > 0)
  .sort((a, b) => b.items.length - a.items.length);
---
<Base title="Toutes les rubriques · Microsave" description="Explorez tous les univers de Microsave : assurance, maison, voyage, bricolage, santé, mode et bien plus.">
  <section class="wrap head">
    <span class="kicker">Le sommaire</span>
    <h1>Explorez toutes les rubriques</h1>
    <p class="intro">{articles.length} articles répartis dans {data.length} univers. Choisissez votre porte d’entrée.</p>
  </section>

  <section class="wrap grid">
    {data.map(({ c, items }, i) => (
      <a class="rub" href={`/categorie/${c.slug}/`} style={`--cc:${c.color}`} data-reveal data-reveal-d={(i % 4) + 1}>
        <div class="top"><span class="n">{items.length}</span><span class="arrow">→</span></div>
        <h2>{c.label}</h2>
        <p>{c.blurb}</p>
        <div class="samples">
          {items.slice(0, 2).map((a) => (<span class="s">{a.title}</span>))}
        </div>
      </a>
    ))}
  </section>
</Base>

<style>
  .head { padding-top: clamp(2rem, 5vw, 3.5rem); max-width: 820px; }
  .head h1 { font-size: clamp(2.4rem, 6vw, 4rem); letter-spacing: -.03em; margin: .4rem 0 .7rem; }
  .intro { font-size: 1.2rem; color: var(--text-soft); }
  .grid { margin-top: clamp(2rem, 4vw, 3rem); display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.3rem; }
  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .grid { grid-template-columns: 1fr; } }
  .rub { border: 1px solid var(--line); border-radius: 22px; padding: 1.5rem 1.5rem 1.6rem; background: #fff; display: flex; flex-direction: column; gap: .5rem; position: relative; overflow: hidden; transition: transform .4s var(--ease), box-shadow .4s var(--ease); }
  .rub::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 5px; background: var(--cc); }
  .rub:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
  .top { display: flex; justify-content: space-between; align-items: center; margin-top: .3rem; }
  .n { font-family: var(--font-display); font-size: 2.6rem; color: var(--cc); line-height: 1; }
  .arrow { font-size: 1.4rem; color: var(--cc); transition: transform .3s var(--ease); }
  .rub:hover .arrow { transform: translateX(6px); }
  .rub h2 { font-size: 1.35rem; }
  .rub p { color: var(--text-soft); font-size: .95rem; line-height: 1.5; }
  .samples { margin-top: .6rem; display: grid; gap: .35rem; border-top: 1px solid var(--line); padding-top: .8rem; }
  .samples .s { font-size: .82rem; color: var(--slate); display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .samples .s::before { content: "› "; color: var(--cc); }
</style>
