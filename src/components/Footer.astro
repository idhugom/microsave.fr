---
import { CATEGORIES } from '../lib/categories';
const year = 2026;
---
<footer class="site-footer">
  <div class="wrap grid">
    <div class="col brandcol">
      <img src="/logo-microsave.svg" alt="Microsave" width="170" height="134" />
      <p>Le magazine des choix malins. On décrypte, on compare, on teste — pour vous aider à décider mieux au quotidien.</p>
      <p class="made">Édité avec passion en France 🇫🇷</p>
    </div>
    <div class="col">
      <h3>Rubriques</h3>
      <ul>
        {CATEGORIES.slice(0, 7).map((c) => <li><a href={`/categorie/${c.slug}/`}>{c.label}</a></li>)}
      </ul>
    </div>
    <div class="col">
      <h3>Explorer</h3>
      <ul>
        {CATEGORIES.slice(7).map((c) => <li><a href={`/categorie/${c.slug}/`}>{c.label}</a></li>)}
        <li><a href="/rubriques/">Toutes les rubriques</a></li>
      </ul>
    </div>
    <div class="col">
      <h3>Le média</h3>
      <ul>
        <li><a href="/">Accueil</a></li>
        <li><a href="/rubriques/">Sommaire</a></li>
        <li><a href="/sitemap-index.xml">Plan du site</a></li>
      </ul>
    </div>
  </div>
  <div class="wrap base">
    <span>© {year} Microsave.fr — Tous droits réservés.</span>
    <span class="dot">•</span>
    <span>Contenus rédigés pour vous éclairer, jamais pour vous vendre du vent.</span>
  </div>
</footer>

<style>
  .site-footer { margin-top: 5rem; background: var(--ink); color: #dfe7ea; padding-top: 3.4rem; position: relative; overflow: hidden; }
  .site-footer::before { content: ""; position: absolute; top: -40%; right: -10%; width: 40vw; height: 40vw; background: radial-gradient(circle, rgba(250,97,154,.22), transparent 65%); pointer-events: none; }
  .grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 2rem; padding-bottom: 2.6rem; }
  .brandcol img { height: 54px; width: auto; filter: brightness(0) invert(1); opacity: .96; margin-bottom: 1rem; }
  .brandcol p { color: #b6c4ca; font-size: .96rem; max-width: 34ch; }
  .made { margin-top: .8rem; font-weight: 600; color: #fff; }
  .col h3 { color: #fff; font-size: 1.05rem; margin-bottom: .9rem; font-family: var(--font-body); font-weight: 650; letter-spacing: .02em; }
  .col ul { list-style: none; padding: 0; display: grid; gap: .5rem; }
  .col a { color: #b6c4ca; font-size: .94rem; transition: color .25s, padding-left .25s; }
  .col a:hover { color: var(--pink); padding-left: 4px; }
  .base { display: flex; flex-wrap: wrap; gap: .6rem; align-items: center; border-top: 1px solid rgba(255,255,255,.12); padding-block: 1.4rem; font-size: .84rem; color: #8ea2aa; }
  .dot { color: var(--pink); }
  @media (max-width: 820px) { .grid { grid-template-columns: 1fr 1fr; } .brandcol { grid-column: 1 / -1; } }
  @media (max-width: 480px) { .grid { grid-template-columns: 1fr; } }
</style>
